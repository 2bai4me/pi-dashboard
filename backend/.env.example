# Pi Dashboard Backend Config (BEISPIEL)
# Kopiere diese Datei nach .env und passe die Werte an.

# Server
PI_DASHBOARD_HOST=127.0.0.1
PI_DASHBOARD_PORT=9219

# Pfade zum lokalen PI-Agent (default: ~/.pi/agent)
PI_AGENT_DIR=C:\Users\uwean\.pi\agent
PI_BIN=pi
PI_CODING_AGENT_PKG=@earendil-works/pi-coding-agent

# Auth (Default: AUS, damit die UI ohne Login funktioniert)
PI_DASHBOARD_AUTH_ENABLED=false
PI_DASHBOARD_JWT_SECRET=change-me-to-a-random-32-byte-base64-secret
PI_DASHBOARD_JWT_TTL_HOURS=24

# Initial-Login (wird beim ersten Start zu bcrypt gehasht)
PI_DASHBOARD_ADMIN_USER=admin
PI_DASHBOARD_ADMIN_PASSWORD=admin

# OpenBrain (optional — fuer semantische Suche ueber Tasks/Sessions)
OPENBRAIN_URL=
OPENBRAIN_ACCESS_KEY=

# CORS (Frontend-URL — bei mehreren kommasepariert)
PI_DASHBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
